---
import ContactForm from "./ContactForm.tsx";
---
<section id="kontakt" class="contact">
  <div class="contact__bg" aria-hidden="true"></div>
  <div class="container contact__grid">
    <div class="contact__intro">
      <h2 class="display contact__title">Er du klar?</h2>
      <p class="contact__lead">Fortell oss kort om bedriften din, så tar vi en uforpliktende prat. Vi svarer som regel innen en dag.</p>
      <a class="contact__mail" href="mailto:hei@klarstudio.no">hei@klarstudio.no</a>
    </div>
    <div class="contact__card">
      <ContactForm client:visible />
    </div>
  </div>
</section>
<style>
  .contact { position: relative; isolation: isolate; color: #fff; overflow: hidden;
    background: var(--accent); padding-block: clamp(4.5rem, 9vw, 8rem); }
  .contact__bg { position: absolute; inset: 0; z-index: -1;
    background:
      radial-gradient(70% 90% at 85% 10%, color-mix(in srgb, #fff 16%, transparent) 0%, transparent 55%),
      linear-gradient(160deg, var(--accent) 0%, var(--accent-deep) 100%);
  }
  .contact__grid { display: grid; gap: 3rem; grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 840px) { .contact__grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }

  .contact__title { font-size: clamp(2.6rem, 1.6rem + 4.5vw, 4.5rem); }
  .contact__lead { color: color-mix(in srgb, #fff 88%, transparent); margin-top: 1.5rem;
    max-width: 38ch; font-size: var(--step-1); line-height: 1.55; }
  .contact__mail { display: inline-block; margin-top: 1.75rem; color: #fff; font-weight: 700;
    text-decoration: underline; text-decoration-thickness: 2px; text-underline-offset: 5px;
    text-decoration-color: color-mix(in srgb, #fff 50%, transparent); transition: text-decoration-color 0.2s ease; }
  .contact__mail:hover { text-decoration-color: #fff; }

  .contact__card { background: #fff; color: var(--ink); border-radius: var(--radius-lg);
    padding: clamp(1.5rem, 4vw, 2.5rem); box-shadow: 0 30px 70px -30px rgba(0,0,0,0.5); }
</style>

<!-- Form lives in a React island, so its styles must be global to reach it. -->
<style is:global>
  .contact__card .form { display: grid; gap: 1.1rem; max-width: none; width: 100%; }
  .form__field { display: grid; gap: 0.4rem; }
  .form__field > span { font-weight: 600; font-size: 0.95rem; }
  .form input, .form textarea {
    font: inherit; width: 100%; color: var(--ink); background: var(--bg);
    padding: 0.85rem 0.95rem; border: 1px solid var(--line-strong); border-radius: 11px;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .form textarea { resize: vertical; min-height: 7rem; }
  .form input::placeholder, .form textarea::placeholder { color: color-mix(in srgb, var(--ink) 52%, white); }
  .form input:focus, .form textarea:focus {
    outline: none; border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .form [aria-invalid="true"] { border-color: #c0263b; }
  .form button {
    justify-self: stretch; width: 100%; background: var(--accent); color: var(--accent-ink); font-weight: 700;
    border: 0; padding: 0.95rem 1.8rem; border-radius: 999px; cursor: pointer; font-size: 1.02rem;
    transition: transform 0.18s var(--ease-out), background 0.18s ease;
  }
  .form button:hover:not(:disabled) { transform: translateY(-1px); background: var(--accent-deep); }
  .form button:active:not(:disabled) { transform: scale(0.98); }
  .form button:disabled { opacity: 0.6; cursor: default; }
  .form__err { color: #c0263b; font-style: normal; font-size: 0.9rem; }
  .form__ok { color: var(--ink); font-weight: 700; font-size: 1.05rem; }
</style>
