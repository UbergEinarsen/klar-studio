---
import { founders } from "../data/founders.ts";
import Reveal from "./Reveal.astro";
---
<section id="om-oss">
  <div class="container">
    <div class="about__head">
      <p class="eyebrow">Om oss</p>
      <h2 class="about__title">To utviklere. Én besettelse: at lokale bedrifter lykkes på nett.</h2>
    </div>
    <div class="about__grid">
      {founders.map((f, i) => (
        <Reveal delay={i * 0.1}>
          <article class="about__person">
            <div class="about__photo"><img src={f.photo} alt={f.name} loading="lazy" /></div>
            <h3>{f.name}</h3>
            <p class="about__role">{f.role}</p>
            <p class="about__bio">{f.bio}</p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
<style>
  .about__head { margin-bottom: clamp(2.75rem, 5vw, 4rem); display: flex; flex-direction: column; gap: 1rem; }
  .about__title { font-size: var(--step-2); max-width: 22ch; }
  .about__grid { display: grid; gap: clamp(1.5rem, 4vw, 2.5rem); grid-template-columns: 1fr; max-width: 620px; }
  @media (min-width: 560px) { .about__grid { grid-template-columns: 1fr 1fr; } }
  .about__photo { overflow: hidden; border-radius: var(--radius); border: 1px solid var(--line);
    background: var(--surface); }
  .about__photo img { display: block; width: 100%; aspect-ratio: 4/5; object-fit: cover;
    transition: transform 0.6s var(--ease-out); }
  .about__person:hover .about__photo img { transform: scale(1.03); }
  .about__person h3 { margin: 1.25rem 0 0.2rem; font-size: 1.3rem; }
  .about__role { color: var(--accent); font-weight: 600; }
  .about__bio { color: var(--muted); margin-top: 0.6rem; max-width: 36ch; }
</style>
