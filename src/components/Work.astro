---
import { projects } from "../data/projects.ts";
import Reveal from "./Reveal.astro";
const featured = projects.find((p) => p.real);
const demos = projects.filter((p) => !p.real);
---
<section id="arbeid">
  <div class="container">
    <div class="work__head">
      <p class="eyebrow">Arbeid</p>
      <h2 class="work__title">Ekte sider, satt i drift.</h2>
    </div>
    {featured && (
      <Reveal>
        <a class="work__featured" href={featured.url} target="_blank" rel="noopener">
          <div class="work__shot">
            <img src={featured.image} alt={featured.name} loading="lazy" />
            <span class="work__visit">Besøk siden <span aria-hidden="true">↗</span></span>
          </div>
          <div class="work__meta">
            <span class="work__tag">Levert</span>
            <h3>{featured.name}</h3>
            <p>{featured.tagline}</p>
          </div>
        </a>
      </Reveal>
    )}
    <div class="work__grid">
      {demos.map((p, i) => (
        <Reveal delay={i * 0.08}>
          <article class="work__demo" data-demo={i}>
            <div class="work__mock" role="img" aria-label={`Konseptskisse: ${p.name}`}>
              <span class="work__badge">Demo</span>
              <span class="work__dots" aria-hidden="true"><i></i><i></i><i></i></span>
              <span class="work__mock-hero" aria-hidden="true"></span>
              <span class="work__mock-line work__mock-line--a" aria-hidden="true"></span>
              <span class="work__mock-line work__mock-line--b" aria-hidden="true"></span>
            </div>
            <h3>{p.name.replace("Demo — ", "")}</h3>
            <p>{p.tagline}</p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
<style>
  .work__head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: clamp(2.75rem, 5vw, 4rem); }
  .work__title { font-size: var(--step-2); }

  .work__featured { display: grid; gap: 1.75rem; text-decoration: none; margin-bottom: clamp(3rem, 6vw, 4.5rem);
    align-items: center; }
  @media (min-width: 880px) { .work__featured { grid-template-columns: 1.55fr 1fr; gap: 3rem; } }

  .work__shot { position: relative; overflow: hidden; border-radius: var(--radius);
    border: 1px solid var(--line); background: var(--surface); box-shadow: var(--shadow); }
  .work__shot img { display: block; width: 100%; aspect-ratio: 16/10; object-fit: cover;
    transition: transform 0.6s var(--ease-out); }
  .work__featured:hover .work__shot img { transform: scale(1.04); }
  .work__visit { position: absolute; left: 1rem; bottom: 1rem;
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--accent); color: var(--accent-ink); font-weight: 600; font-size: 0.9rem;
    padding: 0.5rem 1rem; border-radius: 999px;
    opacity: 0; transform: translateY(8px); transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out); }
  @media (hover: hover) { .work__featured:hover .work__visit { opacity: 1; transform: translateY(0); } }
  @media (hover: none) { .work__visit { opacity: 1; transform: none; } }

  .work__meta { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  .work__tag { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em; color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent); border-radius: 999px;
    padding: 0.2rem 0.7rem; }
  .work__meta h3 { font-size: var(--step-2); margin-top: 0.25rem; }
  .work__meta p { color: var(--muted); max-width: 34ch; }

  .work__grid { display: grid; gap: 1.75rem; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
  .work__demo h3 { margin: 1rem 0 0.25rem; font-size: 1.15rem; }
  .work__demo p { color: var(--muted); font-size: 0.95rem; }

  /* Concept-site preview tiles — a faux browser frame, on-brand, no broken placeholder image. */
  .work__mock { position: relative; overflow: hidden; aspect-ratio: 4/3; border-radius: 14px;
    border: 1px solid var(--line); padding: 2.1rem 1.1rem 1.1rem;
    display: flex; flex-direction: column; gap: 0.7rem; justify-content: flex-end;
    background: linear-gradient(155deg, var(--m1) 0%, var(--m2) 100%);
    transition: transform 0.4s var(--ease-out); }
  .work__demo:hover .work__mock { transform: translateY(-4px); }
  .work__demo[data-demo="0"] { --m1: #1b4dff; --m2: #0a1f7a; }
  .work__demo[data-demo="1"] { --m1: #14213d; --m2: #0a0b14; }
  .work__demo[data-demo="2"] { --m1: #2f6df0; --m2: #123a8f; }
  .work__dots { position: absolute; top: 0.8rem; left: 1rem; display: flex; gap: 5px; }
  .work__dots i { width: 7px; height: 7px; border-radius: 50%; background: color-mix(in srgb, #fff 55%, transparent); }
  .work__mock-hero { height: 38%; border-radius: 8px; background: color-mix(in srgb, #fff 92%, transparent);
    box-shadow: 0 8px 24px -10px rgba(0,0,0,0.4); }
  .work__mock-line { height: 9px; border-radius: 5px; background: color-mix(in srgb, #fff 40%, transparent); }
  .work__mock-line--a { width: 70%; }
  .work__mock-line--b { width: 45%; background: color-mix(in srgb, #fff 26%, transparent); }
  .work__badge { position: absolute; z-index: 2; top: 0.7rem; right: 0.7rem;
    background: color-mix(in srgb, #fff 90%, transparent); color: var(--ink); font-weight: 700; font-size: 0.72rem;
    padding: 0.18rem 0.6rem; border-radius: 999px; letter-spacing: 0.02em; }
</style>
