---
import { services } from "../data/services.ts";
import Reveal from "./Reveal.astro";
---
<section id="tjenester">
  <div class="container">
    <div class="services__head">
      <p class="eyebrow">Tjenester</p>
      <h2 class="services__title">Alt du trenger for å bli funnet og valgt.</h2>
    </div>
    <div class="services__grid">
      {services.map((s, i) => (
        <Reveal delay={i * 0.08}>
          <article class="service">
            <span class="service__rule" aria-hidden="true"></span>
            <h3>{s.title} <span class="service__arrow" aria-hidden="true">→</span></h3>
            <p>{s.body}</p>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
<style>
  .services__head { display: flex; flex-direction: column; gap: 1rem; margin-bottom: clamp(2.75rem, 5vw, 4rem); }
  .services__title { font-size: var(--step-2); max-width: 20ch; }
  .services__grid { display: grid; gap: 2.5rem 3rem; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }

  .service { padding-top: 1.5rem; position: relative; }
  .service__rule { position: absolute; top: 0; left: 0; height: 3px; width: 100%;
    background: var(--line-strong); border-radius: 3px; overflow: hidden; }
  .service__rule::after { content: ""; position: absolute; inset: 0; width: 100%;
    background: var(--accent); transform: scaleX(0); transform-origin: left;
    transition: transform 0.5s var(--ease-out); }
  .service h3 { font-size: clamp(1.3rem, 1.1rem + 0.7vw, 1.6rem); margin-bottom: 0.75rem;
    display: flex; align-items: baseline; gap: 0.4rem; }
  .service__arrow { color: var(--accent); opacity: 0; transform: translateX(-6px);
    transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out); font-size: 0.85em; }
  .service p { color: var(--muted); max-width: 38ch; }

  @media (hover: hover) {
    .service:hover .service__rule::after { transform: scaleX(1); }
    .service:hover .service__arrow { opacity: 1; transform: translateX(0); }
  }
</style>
